{
  "appId": "com.rounds.app",
  "appName": "Rounds",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "versionCode": 4
  },
  "ios": {
    "contentInset": "always"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#488AFF",
      "sound": "beep.wav"
    },
    "Device": {
      "persistUUID": true
    }
  }
}